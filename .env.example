# SOUG XPRESS — Environment Variables
# Copy this file to apps/mobile/.env and fill in your values.
# EXPO_PUBLIC_* variables are bundled into the client at build time.
# They are safe to use with Supabase's publishable anon key.
# Never put service-role keys or private secrets in EXPO_PUBLIC_* vars.

EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_xxxxxxxxxxxxxxxxxxxxxxxxxxxx
